# QuizOnline — least-privilege sudo grants for the `django` app user.
#
# Install on the EC2 host as /etc/sudoers.d/quizonline-deploy:
#     sudo install -m 0440 -o root -g root \
#       deploy/sudoers/quizonline-deploy /etc/sudoers.d/quizonline-deploy
#     sudo visudo -cf /etc/sudoers.d/quizonline-deploy   # must print "parsed OK"
#
# Scope: redeploy.sh (run as `django`) only needs to RESTART the three app
# services and validate + reload nginx. It deliberately can NOT:
#   - install/overwrite systemd unit files, or
#   - run `systemctl daemon-reload`, or
#   - touch apache.
#
# The systemd units are now installed by ROOT, straight from the committed
# git blob (origin/main), in .github/workflows/deploy.yml — never from the
# django-writable working tree. So a compromised `django` can no longer
# place or alter a root-run unit and have it loaded. That closes the prior
# escalation path: editable app tree → cp malicious unit into
# /etc/systemd/system → daemon-reload → restart → root RCE.
#
# (Formerly /etc/sudoers.d/django-deploy — renamed for naming parity with
# the rest of the quizonline-* tooling; the filename is cosmetic.)

Cmnd_Alias QO_SVC_CTRL = \
      /bin/systemctl restart quizonline-gunicorn, \
      /bin/systemctl restart quizonline-celery, \
      /bin/systemctl restart quizonline-celery-beat, \
      /bin/systemctl restart quizonline-gunicorn quizonline-celery quizonline-celery-beat


Cmnd_Alias QO_WEB_CTRL = \
      /usr/sbin/nginx -t, \
      /bin/systemctl reload nginx

django ALL=(root) NOPASSWD: QO_SVC_CTRL, QO_WEB_CTRL
Defaults!QO_SVC_CTRL,QO_WEB_CTRL !setenv, !env_keep
