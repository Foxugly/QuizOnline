# --- Django ---
DJANGO_ENV=prod
DEBUG=False
SECRET_KEY=CHANGE_ME_generate_with_python_c_import_secrets_print_secrets_token_hex_32
JWT_SIGNING_KEY=CHANGE_ME_different_from_SECRET_KEY

# --- Database ---
# Fleet DB_* 6-var convention (OPERATIONS.md §3.13). Prod = box-local PostgreSQL.
# Leave DB_ENGINE unset for a dev sqlite (db.sqlite3).
DB_ENGINE=postgresql
DB_NAME=quizonline
DB_USER=quizonline
DB_PASSWORD=CHANGE_ME
DB_HOST=localhost
DB_PORT=5432

# --- Hosts ---
ALLOWED_HOSTS=YOUR_DOMAIN
CORS_ALLOWED_ORIGINS=https://YOUR_DOMAIN
CSRF_TRUSTED_ORIGINS=https://YOUR_DOMAIN
FRONTEND_BASE_URL=https://YOUR_DOMAIN

# --- Email ---
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=CHANGE_ME
EMAIL_HOST_PASSWORD=CHANGE_ME
DEFAULT_FROM_EMAIL=noreply@YOUR_DOMAIN

# --- Microsoft Graph mail (alternative to SMTP) ---
# Only required when EMAIL_BACKEND=core.email_backends.microsoft_graph.EmailBackend.
# Canonical fleet names GRAPH_* / GRAPH_SENDER (OPERATIONS.md §3.14).
# GRAPH_CLIENT_SECRET seeds as SecureString (see SECRET_KEYS in seed-parameter-store.sh).
#GRAPH_TENANT_ID=
#GRAPH_CLIENT_ID=
#GRAPH_CLIENT_SECRET=
#GRAPH_SENDER=

# --- Cloudflare Turnstile (register / password-reset captcha) — opt-in ---
# Backend secret (validates tokens server-side). Leave unset to disable the
# captcha gate entirely (the SPA hides the widget when the public site key is
# also absent). The PUBLIC site key lives in /quizonline-frontend/prod (below).
#TURNSTILE_SECRET_KEY=

# --- Celery (eager mode for 10 users — no Redis needed) ---
CELERY_TASK_ALWAYS_EAGER=True
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_DEFAULT_QUEUE=celery

# --- Upload ---
MEDIA_ROOT_DIR=media
DATA_UPLOAD_MAX_MEMORY_SIZE=10485760
FILE_UPLOAD_MAX_MEMORY_SIZE=10485760
MAX_UPLOAD_FILE_SIZE=10485760

# --- API ---
API_PAGE_SIZE=20
PASSWORD_RESET_FRONTEND_PATH_PREFIX=/user/reset-password

# --- Error monitoring (Sentry-compatible ingest) — opt-in ---
#
# The backend uses ``sentry-sdk`` and the SDK speaks the Sentry ingest
# protocol. Point the DSN at any compatible endpoint:
#
#   - Sentry (sentry.io) — Developer plan is free up to 5k errors/month
#                          for one user. Sufficient for a solo project.
#   - GlitchTip Cloud (app.glitchtip.com) — open-source, fully Sentry-
#                          SDK-compatible. Free tier: 1k events/month,
#                          unlimited projects. https://glitchtip.com
#   - Self-hosted GlitchTip — single docker-compose, ~200 MB RAM,
#                          no recurring cost. Same SDK, same DSN shape.
#
# Leave SENTRY_DSN empty to skip the SDK init entirely.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
# Release tag for issue tracking — set in CI/CD to the git SHA.
SENTRY_RELEASE=
# Performance sampling: 0.0 = traces off, 1.0 = every request traced.
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0
# Send IP / user / cookies to the ingest endpoint. The SDK still scrubs
# Authorization / Cookie / CSRF headers on its own; what this toggles is
# request-IP, user.id/email when pushed on the scope, and the URL query
# string. Default True for richer debugging — list Sentry/GlitchTip as a
# sub-processor in the privacy policy when keeping it on.
SENTRY_SEND_DEFAULT_PII=True

# Frontend runtime config does NOT live in this file. It is a separate
# SSM prefix with BARE names — /quizonline-frontend/prod/* (like
# pushit-frontend / tm-frontend, OPERATIONS.md §3.14) — fetched at boot
# (and after every CI deploy) by quizonline-frontend-runtime-fetch.service,
# which writes /etc/nginx/snippets/quizonline-frontend-runtime.conf and
# reloads nginx. The Angular bundle reads window.__QUIZONLINE_SENTRY_* at
# boot, sub_filter-injected from that snippet. All four keys are public
# String (they ship in the SPA):
#   /quizonline-frontend/prod/SENTRY_DSN
#   /quizonline-frontend/prod/SENTRY_ENV          (default "production")
#   /quizonline-frontend/prod/SENTRY_RELEASE      (set by CI to the git SHA)
#   /quizonline-frontend/prod/TURNSTILE_SITE_KEY  (public Turnstile site key)
# Seed them with: bash deploy/seed-parameter-store.sh --prefix \
#   /quizonline-frontend/prod ./frontend.env
# Leave SENTRY_DSN empty to keep the frontend SDK off.

# LMS throttles
THROTTLE_LMS_ENROLL=20/min
THROTTLE_LMS_BLOCK_WRITE=120/min
THROTTLE_LMS_CERT_VERIFY=60/min

# Connection-log throttle — caps the per-user POST /api/connection-log/ that
# the SPA fires after each successful login. Seeds into SSM like the LMS
# throttles above (see deploy/README.md → throttles).
THROTTLE_CONNECTION_LOG=30/min

# --- Geolocation (MaxMind GeoLite2, offline) ---
# Directory holding GeoLite2-City.mmdb on the server (e.g. /var/lib/geoip).
# Leave empty to disable geolocation entirely — the connection log then stores
# events with empty geo fields (graceful degradation, no errors). Provision the
# DB per deploy/README.md → "MaxMind GeoLite2 geolocation".
GEOIP_PATH=
# MaxMind credentials used by quizonline-geoip-fetch.service to download
# GeoLite2-City.mmdb into GEOIP_PATH (NOT read by Django itself). Account ID as
# String, license key as SecureString. Seed into SSM /quizonline/prod/*.
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=
