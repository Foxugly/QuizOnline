# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Python / Django ───────────────────────────────────────────────────────────
.venv/
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

quizonline-server/.env
quizonline-server/.env.*
!quizonline-server/.env.example
quizonline-server/db.sqlite3
quizonline-server/db.*.sqlite3
quizonline-server/staticfiles/
quizonline-server/media/question_media/*
!quizonline-server/media/question_media/dummy.txt
quizonline-server/media/lms/

# Compiled gettext message catalogs (build from .po via `manage.py compilemessages`)
quizonline-server/locale/**/*.mo

# MaxMind GeoLite2 databases — provisioned on the server (see deploy/README.md),
# never committed (large binary, licensed, refreshed monthly).
*.mmdb

# ── Node / Angular ────────────────────────────────────────────────────────────
node_modules/
quizonline-frontend/dist/
quizonline-frontend/.angular/
quizonline-frontend/coverage/
quizonline-frontend/test-results/
quizonline-frontend/playwright-report/
.playwright-mcp/

# Smoke-test artefacts saved to the repo root by Playwright sessions and
# ad-hoc markdown notes from past audits. Anchored to repo root so checked-in
# screenshots under quizonline-frontend/src/assets/, docs/, etc. are unaffected.
# CLAUDE.md and README.md are explicitly re-included as the only intended
# root-level markdown.
/*.png
/*.jpeg
/*.jpg
/*.md
/*.pptx
!/CLAUDE.md
!/README.md

# ── Secrets / credentials that operators might stage at repo root ─────────────
# Defensive — covers ad-hoc files like prod.env / staging.env used as input
# to deploy/seed-parameter-store.{sh,ps1}, and stray AWS access-key dumps /
# SSH key exports. These should NEVER be committed; this catch-all means a
# tired ``git add .`` doesn't end the day on a leak.
/*.env
AWS*
*.pem
*.ppk
/*.csv

# ── Scratch / generated artifacts (never commit; keep `git add -A` safe) ──────
/.tmp/
/PycharmProjectsQuizOnline.tmp_index.html
# Manual PDFs are generated on demand (npm run manual:pdf), not version-controlled.
docs/manual/QuizOnline-Manuel-*.pdf
docs/manual/**/.manual-build.html

# ── Claude Code ───────────────────────────────────────────────────────────────
.claude/scheduled_tasks.lock
