# ─── Django core ──────────────────────────────────────────────────────────────
DEBUG=True
SECRET_KEY=replace-with-a-random-secret-of-at-least-32-bytes
# Separate signing key for JWT tokens (required in production, distinct from SECRET_KEY)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SIGNING_KEY=
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ─────────────────────────────────────────────────────────────────
# The URL scheme determines the engine:
#   SQLite     : sqlite:///db.sqlite3
#   PostgreSQL : postgresql://user:pass@host:5432/dbname
#   MySQL      : mysql://user:pass@host:3306/dbname
DATABASE_URL=sqlite:///db.sqlite3

# ─── CORS / CSRF ──────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
# Required in production (must match CORS_ALLOWED_ORIGINS)
CSRF_TRUSTED_ORIGINS=

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_BASE_URL=http://127.0.0.1:4200
PASSWORD_RESET_FRONTEND_PATH_PREFIX=/user/reset-password

# ─── Email ────────────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
#EMAIL_BACKEND=core.email_backends.microsoft_graph.EmailBackend
DEFAULT_FROM_EMAIL=
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MS_GRAPH_SENDER_USER_ID=

# ─── Celery ───────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
CELERY_TASK_ALWAYS_EAGER=True
CELERY_TASK_DEFAULT_QUEUE=quizonline

# ─── API ──────────────────────────────────────────────────────────────────────
API_PAGE_SIZE=20

# ─── Uploads ──────────────────────────────────────────────────────────────────
DATA_UPLOAD_MAX_MEMORY_SIZE=10485760
FILE_UPLOAD_MAX_MEMORY_SIZE=10485760
MAX_UPLOAD_FILE_SIZE=10485760
MEDIA_ROOT_DIR=media

# ─── DeepL translation ────────────────────────────────────────────────────────
USE_DEEPL=False
DEEPL_IS_FREE=True
DEEPL_AUTH_KEY=

# ─── Sentry ───────────────────────────────────────────────────────────────────
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=quizonline-1.0.0
SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_PROFILES_SAMPLE_RATE=0.0

# ─── DRF throttle rates ──────────────────────────────────────────────────────
# Format: ``<int>/<period>`` where period is ``second|minute|hour|day``.
# Each line is the fallback shipped in code; uncomment + edit only the
# ones you want to override.
#THROTTLE_TOKEN_OBTAIN=5/min
#THROTTLE_PASSWORD_RESET=3/hour
#THROTTLE_PASSWORD_RESET_CONFIRM=10/hour
#THROTTLE_EMAIL_CONFIRM=10/hour
#THROTTLE_QUIZ_ANSWER=60/min
#THROTTLE_ADMIN=30/min
#THROTTLE_ADMIN_EMAIL_TEST=5/min
#THROTTLE_QUIZ_EXPORT=20/min
# Single-domain invite path: up to ``len(emails)`` mails per hit
# (emails capped at 50 by the serializer).
#THROTTLE_DOMAIN_INVITE=100/hour
# Multi-domain fan-out path (``additional_domain_ids`` non-empty):
# one hit can mail up to ``len(emails) × (1 + len(extras))`` people,
# so the per-hour budget must be much tighter than the single-domain
# path. Re-tune carefully — lifting this above ~10/hour reintroduces
# the amplification the split was added to prevent.
#THROTTLE_DOMAIN_INVITE_FANOUT=5/hour
#THROTTLE_MAGIC_LINK_REQUEST=3/hour
#THROTTLE_MAGIC_LINK_EXCHANGE=30/min
